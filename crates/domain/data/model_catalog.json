      "default_model": "claude-sonnet-4-6",
      "seed_multimodal_from_reasoning": true,
      "extra_lanes": []
    },
    {
      "id": "openrouter",
      "title": "OpenRouter",
      "description": "Reasoning lane plus cheap Qwen summary and embedding defaults.",
      "default_provider": "openrouter",
      "default_model": "anthropic/claude-sonnet-4-6",
      "seed_multimodal_from_reasoning": false,
      "extra_lanes": [
        {
          "lane": "cheap_reasoning",
          "candidates": [
            {
              "provider": "openrouter",
              "model": "deepseek/deepseek-v4"
            },
            {
              "provider": "openrouter",
              "model": "qwen/qwen3.5-plus"
            }
          ]
        },
        {
          "lane": "embedding",
          "candidates": [
            {
              "provider": "openrouter",
              "model": "qwen/qwen3-embedding-8b",
              "dimensions": 4096,
              "profile": {
                "features": ["embedding"]
              }
            }
          ]
        }
      ]
    },
