{
  "presets": [
    {
      "id": "chatgpt",
      "title": "ChatGPT / Codex",
      "description": "OpenAI-style reasoning lane with minimal defaults.",
      "default_provider": "openai-codex",
      "default_model": "gpt-5.4",
      "seed_multimodal_from_reasoning": true,
      "extra_lanes": []
    },
    {
      "id": "claude",
      "title": "Claude",
